{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "dist/**",
      "ui/dist/**",
      "ui/node_modules/**",
      "node_modules/**",
      "spike/**",
      "fixtures/**",
      "grammars/**",
      "demo/**",
      ".playwright-mcp/**",
      ".remember/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
