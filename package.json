{
  "name": "crashpath",
  "version": "0.1.0",
  "description": "Paste a stack trace, see the failure as a path through your codebase graph. Post-mortem, local-first, zero setup.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "crashpath": "./dist/cli/index.js"
  },
  "files": ["dist", "grammars", "demo"],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm --prefix ui run build",
    "e2e": "playwright test",
    "test": "vitest run",
    "corpus": "vitest run tests/corpus.test.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.6.0",
    "source-map-js": "^1.2.1",
    "web-tree-sitter": "0.20.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hq525/Trace-Visualizer.git"
  },
  "homepage": "https://github.com/hq525/Trace-Visualizer#readme",
  "bugs": {
    "url": "https://github.com/hq525/Trace-Visualizer/issues"
  },
  "keywords": [
    "stack-trace",
    "traceback",
    "debugging",
    "visualization",
    "post-mortem",
    "tree-sitter",
    "sourcemap",
    "mcp"
  ]
}
